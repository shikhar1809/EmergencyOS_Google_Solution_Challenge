rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /// Master ops email (must match `functions/index.js` `isMasterConsoleEmailToken`).
    /// Accepts both the correct spelling and the legacy typo so we don't break
    /// any existing bound console account while the rename is rolling out.
    function isMasterOpsConsoleEmail() {
      return request.auth != null
        && request.auth.token.email != null
        && (
          request.auth.token.email.lower() == 'admin@emergencyos.com'
          || request.auth.token.email.lower() == 'admin@emeregencyos.com'
        );
    }

    /// Hospital staff: `users/{uid}.staffHospitalId` or `boundHospitalDocId` matches doc id.
    function userHospitalBindingMatches(hospitalDocId) {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) && (
        get(userPath).data.get('staffHospitalId', '') == hospitalDocId
        || get(userPath).data.get('boundHospitalDocId', '') == hospitalDocId
      );
    }

    /// Keys hospital Live Ops / analytics may merge (not credentials or gate secrets).
    function opsHospitalLiveOpsMutableKeysOnly() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'bedsAvailable', 'bedsTotal', 'traumaBedsNote',
          'offeredServices', 'hasBloodBank', 'mapListingOnline',
          'doctorsOnDuty', 'specialistsOnCall', 'bloodUnitsAvailable',
          'updatedAt', 'lat', 'lng', 'geohash'
        ]);
    }

    /// `ops_incident_hospital_assignments/{incidentId}` shows this user's hospital accepted the consignment.
    function incidentAcceptedByUserHospital(incidentId) {
      let ap = /databases/$(database)/documents/ops_incident_hospital_assignments/$(incidentId);
      return exists(ap)
        && get(ap).data.get('dispatchStatus', '') == 'accepted'
        && userHospitalBindingMatches(get(ap).data.get('acceptedHospitalId', ''));
    }

    /// Hospital dashboard / command center: assign EMS unit (`IncidentService.adminAssignAmbulanceDriver`).
    function isAmbulanceDispatchOpsPatch() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'emsWorkflowPhase',
          'emsAcceptedAt',
          'emsAcceptedBy',
          'status',
          'etaUpdatedAt',
          'ambulanceEta',
          'updatedAt'
        ]);
    }

    /// Authenticated fleet operator doc matches the assignment queue call sign.
    function fleetOperatorOwnsCallSign(callSign) {
      let up = /databases/$(database)/documents/ops_fleet_units/$(request.auth.uid);
      return exists(up)
        && get(up).data.get('fleetCallSign', '') == callSign;
    }

    /// Client-created pending assignment (`FleetAssignmentService.sendAssignment`).
    function isFleetPendingAssignmentCreate(callSign) {
      return request.resource.data.keys().hasOnly([
          'fleetId', 'incidentId', 'vehicleType', 'callSign', 'status',
          'source', 'dispatchedAt', 'responseDeadlineAt'
        ])
        && request.resource.data.get('fleetId', '') == callSign
        && request.resource.data.get('status', '') == 'awaiting_response';
    }

    // ── Users: own profile read/write; Cloud Functions use Admin SDK (bypasses rules) ──
    match /users/{uid} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Volunteer presence: anyone authenticated can read (map); own write only ──
    match /volunteers/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── SOS Incidents: victim creates, authenticated peers read, CF owns writes ──
    //
    // NOTE: `allow read` is intentionally broad because the main app needs to
    // stream the live incident pool for the volunteer map, leaderboard counts,
    // and peer situational awareness. A follow-up will move these aggregations
    // to server-computed public views (see docs/SECURITY.md → "Incident read
    // scoping roadmap") so we can tighten this rule without breaking clients.
    match /sos_incidents/{id} {
      /// A volunteer's first "Accept" must add themselves to
      /// `acceptedVolunteerIds` and may only touch a whitelisted set of
      /// fields that the client-side accept transaction actually writes
      /// (see `IncidentService.acceptIncident`). This lets the swipe-to-
      /// accept flow work without widening update access for arbitrary
      /// callers.
      function isVolunteerSelfAccept() {
        return request.auth != null
          && request.auth.uid in request.resource.data.get('acceptedVolunteerIds', [])
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly([
                'acceptedVolunteerIds',
                'status',
                'firstAcknowledgedAt',
                'firstAcknowledgedByUid',
                'responderNames'
              ]);
      }

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow read:   if request.auth != null;
      // Victim, accepted volunteers, and allotted EMS / crane units (fleet app) can update.
      // Plus a constrained self-accept path so a volunteer can add themselves
      // to `acceptedVolunteerIds` for the first time.
      allow update: if request.auth != null
                    && (
                      request.auth.uid == resource.data.userId
                      || request.auth.uid in resource.data.get('acceptedVolunteerIds', [])
                      || request.auth.uid == resource.data.emsAcceptedBy
                      || request.auth.uid == resource.data.craneUnitAcceptedBy
                      || isVolunteerSelfAccept()
                      || (isMasterOpsConsoleEmail() && isAmbulanceDispatchOpsPatch())
                      || (incidentAcceptedByUserHospital(id) && isAmbulanceDispatchOpsPatch())
                    );
      // Client-side archive (victim resolve / fleet response complete) removes active doc.
      allow delete: if request.auth != null
                    && (
                      request.auth.uid == resource.data.userId
                      || request.auth.uid == resource.data.emsAcceptedBy
                    );
    }

    // ── Incident audit log: append-only timeline written by the app during
    //    accept / dispatch / resolve transitions. Staff dashboards also read
    //    this via a collectionGroup query, so `read` is broad for any signed-in
    //    user. Create is locked down to the authenticated actor; no updates
    //    or deletes from clients.
    match /sos_incidents/{id}/audit_log/{logId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.actorUid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Incident archive: read-only; CF writes via Admin SDK ─────────────────
    match /sos_incidents_archive/{id} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Narrative incident reports: staff UI reads via collectionGroup, ──────
    //    clients generate one after an incident closes. Create only; no
    //    after-the-fact mutation.
    match /{path=**}/incident_reports/{reportId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── Counters (incident sequence numbers per area) ─────────────────────────
    //    Transactional writes from the client; safe to share since IDs are
    //    opaque integers not tied to PII.
    match /counters/{id} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Hospital registry: read for authenticated; staff merge Live Ops fields ─
    match /ops_hospitals/{id} {
      allow read:  if request.auth != null;
      allow create, delete: if false;
      allow update: if request.auth != null && (
        isMasterOpsConsoleEmail()
        || (userHospitalBindingMatches(id) && opsHospitalLiveOpsMutableKeysOnly())
      );
    }

    // ── Hospital assignments: read for authenticated; CF writes only ──────────
    match /ops_incident_hospital_assignments/{id} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Hospital inbox: per-hospital persistent queue written by the v2
    //    dispatch engine. Each hospital's staff can only read their own inbox;
    //    master console reads any. Writes are Cloud Functions only.
    match /hospital_inbox/{hospitalId}/incidents/{incidentId} {
      allow read:  if request.auth != null && (
                     isMasterOpsConsoleEmail()
                     || userHospitalBindingMatches(hospitalId)
                   );
      allow write: if false;
    }

    // ── Rolling reliability stats (accept/decline/timeout counts) that the
    //    v2 dispatch engine reads when scoring candidates. Authenticated read
    //    for the ops console; writes by Cloud Functions only.
    match /hospital_reliability/{hospitalId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Fleet units: read for authenticated; operators update heartbeat ───────
    match /ops_fleet_units/{id} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Fleet assignment queues: hospital/master create notify; operator responds ─
    match /ops_fleet_assignments/{callSign}/pending/{docId} {
      allow read:  if request.auth != null;
      allow create: if request.auth != null
                    && isFleetPendingAssignmentCreate(callSign)
                    && (
                      isMasterOpsConsoleEmail()
                      || incidentAcceptedByUserHospital(request.resource.data.get('incidentId', ''))
                    );
      allow update: if request.auth != null
                    && fleetOperatorOwnsCallSign(callSign)
                    && (
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['status', 'respondedAt'])
                      || request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['status', 'expiredAt', 'reason'])
                    );
      allow delete: if request.auth != null && fleetOperatorOwnsCallSign(callSign);
    }

    // ── PTT channels: any authenticated participant can read/post ─────────────
    match /ptt_channels/{incidentId} {
      allow read, write: if request.auth != null;
      match /messages/{msgId} {
        allow read:   if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ── Leaderboard: public read; CF writes only ──────────────────────────────
    match /leaderboard/{uid} {
      allow read:  if true;
      allow write: if false;
    }

    // ── AED locations: public read; CF/webhook writes only ───────────────────
    match /aeds/{id} {
      allow read:  if true;
      allow write: if false;
    }

    // ── Ops dashboard alerts: authenticated read (admin UI); CF writes ─────────
    match /ops_dashboard_alerts/{id} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Ops health metrics: authenticated read; CF increments ─────────────────
    match /ops_health_metrics/{id} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── LiveKit bridge records: CF writes; participants read ──────────────────
    match /livekit_bridges/{id} {
      allow read:  if request.auth != null;
      allow write: if false;
    }
    match /livekit_copilot_dispatches/{id} {
      allow read:  if request.auth != null && request.auth.uid == id;
      allow write: if false;
    }

    // ── Preparedness events / webhook log: authenticated read ─────────────────
    match /preparedness_events/{id} {
      allow read:  if request.auth != null;
      allow write: if false;
    }
    match /webhook_events/{id} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Lifeline response cache: CF reads/writes; no client write ─────────────
    match /lifeline_response_cache/{id} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Default: deny everything not explicitly matched ───────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

