{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": [
    {
      "bucket": "emergencyos-101.firebasestorage.app",
      "rules": "storage.rules"
    }
  ],
  "hosting": [
    {
      "target": "main",
      "public": "build/web-main",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "/main.dart.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, max-age=0"
            }
          ]
        },
        {
          "source": "/flutter_service_worker.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, max-age=0"
            }
          ]
        },
        {
          "source": "/flutter_bootstrap.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, max-age=0"
            }
          ]
        },
        {
          "source": "/assets/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, max-age=0"
            }
          ]
        }
      ]
    },
    {
      "target": "admin",
      "public": "build/web-admin",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "/main.dart.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, max-age=0"
            }
          ]
        },
        {
          "source": "/flutter_service_worker.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, max-age=0"
            }
          ]
        },
        {
          "source": "/flutter_bootstrap.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, max-age=0"
            }
          ]
        },
        {
          "source": "/assets/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, max-age=0"
            }
          ]
        }
      ]
    },
    {
      "target": "fleet",
      "public": "build/web-fleet",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "/main.dart.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, max-age=0"
            }
          ]
        },
        {
          "source": "/flutter_service_worker.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, max-age=0"
            }
          ]
        },
        {
          "source": "/flutter_bootstrap.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, max-age=0"
            }
          ]
        },
        {
          "source": "/assets/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, max-age=0"
            }
          ]
        }
      ]
    }
  ],
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        ".env",
        ".env.*",
        ".env.secrets"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint --if-present"
      ]
    }
  ],
  "auth": {
    "providers": {
      "anonymous": true,
      "emailPassword": true
    }
  }
}
