# Copy to .env for Firebase emulator / local Functions testing (never commit .env).
#
# Production (recommended):
#   firebase functions:secrets:set LIVEKIT_API_SECRET
#   firebase functions:secrets:access LIVEKIT_API_SECRET   # verify — no trailing newline/spaces
# Set as Firebase params (or GCP env on the function runtime):
#   LIVEKIT_URL=wss://<subdomain>.livekit.cloud
#   LIVEKIT_API_KEY=<key from same LiveKit project as the secret>
#
# If you use Secret Manager for LIVEKIT_API_SECRET, do NOT also set a conflicting
# LIVEKIT_API_SECRET plain env var in Google Cloud Console — that caused "invalid token"
# for some deployments. Remove duplicate env vars, redeploy.
#
# LIVEKIT_URL may be wss:// or https://. Server SDK uses https; clients get wss://.
#
# If listRooms still fails with "invalid token", set the HTTPS API origin explicitly
# (no path, same subdomain as in LiveKit Cloud dashboard):
#   LIVEKIT_HTTP_URL=https://<subdomain>.livekit.cloud
#
# Production: for parameterized config, create functions/.env.<PROJECT_ID> (gitignored), e.g.
#   functions/.env.emergencyos-101
# with LIVEKIT_URL, LIVEKIT_HTTP_URL, LIVEKIT_API_KEY matching the same LiveKit project as the secret.
#
# Dashboard check: Settings → confirm API Key id matches LIVEKIT_API_KEY; rotate keys if exposed.

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_HTTP_URL=https://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
