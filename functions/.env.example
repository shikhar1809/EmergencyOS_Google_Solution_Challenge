# Copy to .env for Firebase emulator / local Functions testing (never commit .env).
# Production: set LIVEKIT_API_SECRET via Secret Manager:
#   firebase functions:secrets:set LIVEKIT_API_SECRET
# And set LIVEKIT_URL + LIVEKIT_API_KEY as Firebase params or GCP env vars on the function.

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
